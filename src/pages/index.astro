---
import { date } from "astro:schema";
import Layout from "../layouts/Layout.astro";
import styles from "virtual:astro:image-styles.css";

const temperature = 50;
const humidity = 30;
const soilMoisture = "やや乾";
let humidityMessage = "";
let temperatureMessage = "";
let soilMoistureMessage = "";
let d = new Date();
const hours = d.getHours();
// const hours = 20;
console.log(hours);
const box = "humidityBox";

if (humidity < 59) {
	// humidityMessage = "乾燥しています。\n花が落ちてしまうリスクがあります";
	humidityMessage = "高乾燥";
}
if (humidity > 81) {
	// humidityMessage = "多湿状態です。\n病気や根腐れの原因となります";
	humidityMessage = "高湿度";
}
if (humidity >= 60 && humidity <= 80) {
	// humidityMessage = "最適な湿度です\n維持してください";
	humidityMessage = "最適";
}
if (hours >= 9 && hours < 18) {
	if (temperature < 25) {
		// temperatureMessage = "気温が低すぎます";
		temperatureMessage = "低い";
	}
	if (temperature > 30) {
		// temperatureMessage = "気温が高すぎます";
		temperatureMessage = "高い";
	}
	if (temperature >= 25 && temperature <= 30) {
		// temperatureMessage = "最適温度です";
		temperatureMessage = "最適";
	}
} else if (hours >= 18 || hours < 9) {
	if (temperature < 10) {
		// temperatureMessage = "気温が低すぎます";
		temperatureMessage = "低い";
	}
	if (temperature > 15) {
		// temperatureMessage = "気温が高すぎます";
		temperatureMessage = "高い";
	}
	if (temperature >= 10 && temperature <= 15) {
		// temperatureMessage = "最適温度です";
		temperatureMessage = "最適";
	}
}
---

<Layout>
	<div class="main">
		<h1>HOME</h1>
		<div class="date">
			<div class="stats">
				<div class="value">
					<span class="material-symbols-outlined">
						device_thermostat
					</span>
					<h2>温度</h2>
				</div>
				<p>{temperature}</p>
				{
					humidityMessage && (
						<p class="message" id="humidityBox">
							{humidityMessage}
						</p>
					)
				}
			</div>
			<div class="stats">
				<div class="value">
					<span class="material-symbols-outlined"> cool_to_dry </span>
					<h2>湿度</h2>
				</div>
				<p>{humidity}</p>
				{
					temperatureMessage && (
						<p class="message" id="temperatureBox">
							{temperatureMessage}
						</p>
					)
				}
			</div>
			<div class="stats">
				<div class="value">
					<span class="material-symbols-outlined"> psychiatry </span>
					<h2>水分</h2>
				</div>
				<p>{soilMoisture}</p>
				{humidityMessage && <p class="message">{humidityMessage}</p>}
			</div>
		</div>
		<div class="humidity_content">
			<h3>湿度</h3>
			{humidityMessage && <p class="message">{humidityMessage}</p>}
		</div>
		<div class="tempera_content">
			<h3>温度</h3>
			{temperatureMessage && <p class="message">{temperatureMessage}</p>}
		</div>
		<div class="humidity_content">
			<h3>土壌</h3>
			{humidityMessage && <p class="message">{humidityMessage}</p>}
		</div>

		<div class="btn">
			<a href="#">詳しく見る</a>
		</div>
	</div>
</Layout>

<style lang="scss">
	.main {
		padding: 0px 24px;
	}
	.stats {
		display: flex;
		justify-content: space-between;
		width: 100%;
		background-color: #fff;
		padding: 16px;
		border-radius: 32px;
		align-items: center;
		p {
			color: #fff;
			font-size: 18px;
			padding: 4px 16px;
			border-radius: 1000px;
			background-color: #666;
		}
	}
	.date {
		display: flex;
		flex-direction: column;
		gap: 24px;
		justify-content: flex-start;
		align-items: start;
		.value {
			display: flex;
			justify-content: center;
			align-items: center;
			flex-direction: column;
			h2 {
				margin: 0;
			}
		}
	}
	.message {
		white-space: pre-line;
	}
	.humidity_content {
	}
	.btn {
		font-size: 18px;
		display: flex;
		justify-content: center;
		background-color: #006d41;
		border-radius: 8px;
		box-shadow: 10px #000;
		a {
			color: #fff;
			text-decoration: none;
		}
	}
</style>
